# Copy this to .env and fill in your actual secrets
# JWT
APP_JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars

# Tencent Cloud SMS
APP_TENCENT_SECRET_ID=your_secret_id
APP_TENCENT_SECRET_KEY=your_secret_key
APP_TENCENT_SDK_APP_ID=your_sdk_app_id
APP_TENCENT_SIGN_NAME=your_sign_name
APP_TENCENT_TEMPLATE_ID=your_template_id

# WeChat
APP_WECHAT_APP_ID=your_wechat_app_id
APP_WECHAT_APP_SECRET=your_wechat_app_secret
